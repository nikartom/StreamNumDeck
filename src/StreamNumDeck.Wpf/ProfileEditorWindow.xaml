<Window x:Class="StreamNumDeck.Wpf.ProfileEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="540" Height="520"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True"
        ResizeMode="NoResize" Background="Transparent"
        Foreground="#F5F5F5" ShowInTaskbar="False">
    <Window.Resources>
        <Style x:Key="ProfileIconItemStyle" TargetType="ListBoxItem">
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="48" />
            <Setter Property="Margin" Value="3" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="ToolTip" Value="{Binding Name}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="IconBorder"
                                Background="#2B2B2B"
                                BorderBrush="#414141"
                                BorderThickness="1"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="IconBorder" Property="Background" Value="#383838" />
                                <Setter TargetName="IconBorder" Property="BorderBrush" Value="#686868" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="IconBorder" Property="Background" Value="#34435E" />
                                <Setter TargetName="IconBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="10" Background="#202020" BorderBrush="#4B4B4B" BorderThickness="1" CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="22" ShadowDepth="5" Opacity="0.55" Color="#000000" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44" />
                <RowDefinition Height="*" />
                <RowDefinition Height="64" />
            </Grid.RowDefinitions>

            <Border Background="#262626" CornerRadius="12,12,0,0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                               Margin="18,0,48,0" VerticalAlignment="Center"
                               FontSize="13" FontWeight="SemiBold" />
                    <Button HorizontalAlignment="Right" Width="44" Height="44"
                            Background="Transparent" BorderThickness="0" Click="Close_Click">
                        <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE8BB;" FontSize="12" />
                    </Button>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="22,18,22,18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border x:Name="ValidationBorder" Visibility="Collapsed"
                        Background="#3A2022" BorderBrush="#D13438" BorderThickness="1"
                        CornerRadius="7" Padding="12,9" Margin="0,0,0,12">
                    <DockPanel>
                        <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xEA39;" Foreground="#FF99A4" Margin="0,0,9,0" />
                        <TextBlock x:Name="ValidationText" Foreground="#FFD9DC" TextWrapping="Wrap" />
                    </DockPanel>
                </Border>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="76" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <Border Width="64" Height="64" HorizontalAlignment="Left"
                            Background="#2B2B2B" BorderBrush="#505050" BorderThickness="1" CornerRadius="10">
                        <TextBlock x:Name="IconPreviewGlyph" FontFamily="Segoe Fluent Icons" FontSize="28"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock x:Name="NameLabel" Margin="0,0,0,6" />
                        <TextBox x:Name="NameTextBox" Height="34" MaxLength="80" TextChanged="NameTextBox_TextChanged" />
                    </StackPanel>
                </Grid>

                <TextBlock x:Name="IconLabel" Grid.Row="2" Margin="0,18,0,8"
                           FontSize="14" FontWeight="SemiBold" />

                <ListBox x:Name="IconListBox" Grid.Row="3"
                         Background="Transparent" BorderThickness="0" Padding="0"
                         SelectedValuePath="Id" SelectionChanged="IconListBox_SelectionChanged"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ItemContainerStyle="{StaticResource ProfileIconItemStyle}">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Glyph}" FontFamily="Segoe Fluent Icons" FontSize="21"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <Border Grid.Row="2" Background="#262626" BorderBrush="#3C3C3C" BorderThickness="0,1,0,0" CornerRadius="0,0,12,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="18,0">
                    <Button x:Name="CancelButton" MinWidth="84" Margin="0,0,8,0" IsCancel="True" />
                    <Button x:Name="SaveButton" MinWidth="88" IsDefault="True" Click="Save_Click" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
