<Window x:Class="StreamNumDeck.Wpf.Overlays.MicrophoneMuteOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="72" Height="72"
        WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ShowActivated="False"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Border Background="#D9222222" BorderBrush="#55FFFFFF" BorderThickness="1" CornerRadius="14">
        <Grid>
            <TextBlock Text="&#xE720;" FontFamily="Segoe Fluent Icons" Foreground="White" FontSize="34" HorizontalAlignment="Center" VerticalAlignment="Center" />
            <Border Width="48" Height="4" Background="#E8393D" CornerRadius="2" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform><RotateTransform Angle="-42" /></Border.RenderTransform>
            </Border>
        </Grid>
    </Border>
</Window>
