<Window x:Class="StreamNumDeck.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:presentation="clr-namespace:StreamNumDeck.Wpf.Presentation"
        xmlns:localization="clr-namespace:StreamNumDeck.Wpf.Localization"
        Title="StreamNumDeck"
        Width="500" Height="720"
        MinWidth="500" MaxWidth="500"
        MinHeight="720" MaxHeight="720"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="{StaticResource WindowBackgroundBrush}"
        Foreground="#F5F5F5"
        Icon="Assets/AppIcon.ico"
        Loaded="Window_Loaded">
    <Window.Resources>
        <presentation:ProfileGlyphConverter x:Key="ProfileGlyphConverter" />

        <DataTemplate x:Key="DeckKeyTemplate">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid Width="{Binding IconDimension}"
                      Height="{Binding IconDimension}"
                      Visibility="{Binding IconAreaVisibility}">
                    <TextBlock Text="{Binding Glyph}"
                               FontFamily="Segoe Fluent Icons"
                               FontSize="{Binding GlyphFontSize}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="{Binding GlyphVisibility}" />
                    <Image Source="{Binding CustomIconSource}"
                           Stretch="Uniform"
                           Visibility="{Binding CustomIconVisibility}" />
                </Grid>
                <TextBlock Text="{Binding Label}"
                           Margin="{Binding LabelMargin}"
                           Visibility="{Binding LabelVisibility}"
                           MaxWidth="82"
                           FontSize="12"
                           TextAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </DataTemplate>

        <Style x:Key="ChromeButtonStyle" TargetType="Button" BasedOn="{StaticResource DeckKeyButtonStyle}">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="32" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="ZoneToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="20" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Track" Width="38" Height="20"
                                Background="#3A3A3A" BorderBrush="#666666"
                                BorderThickness="1" CornerRadius="10">
                            <Ellipse x:Name="Thumb" Width="14" Height="14" Margin="2"
                                     HorizontalAlignment="Left" Fill="#D8D8D8" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="BorderBrush" Value="#8A8A8A" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="Track" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="Thumb" Property="Fill" Value="#172033" />
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Background="#1B1B1B" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Margin="12,0,0,0" VerticalAlignment="Center">
                <Image Source="Assets/AppIcon.ico" Width="16" Height="16" />
                <TextBlock Text="StreamNumDeck" Margin="9,0,0,0" Foreground="#C9C9C9" FontSize="12" />
            </StackPanel>
            <Button Grid.Column="1" Style="{StaticResource ChromeButtonStyle}" Click="Minimize_Click" ToolTip="{localization:Loc Common_Minimize, Fallback=Minimize}">
                <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE921;" FontSize="10" />
            </Button>
            <Button Grid.Column="2" Style="{StaticResource ChromeButtonStyle}" Click="Close_Click" ToolTip="{localization:Loc Common_Close, Fallback=Close}">
                <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE8BB;" FontSize="10" />
            </Button>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="58" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Background="#191919" BorderBrush="#303030" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="48" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="48" />
                    </Grid.RowDefinitions>
                    <Button Margin="7,5" Style="{StaticResource DeckKeyButtonStyle}" Click="NewProfile_Click" ToolTip="{localization:Loc Nav_NewProfile.ToolTipService.ToolTip, Fallback=New profile}">
                        <TextBlock Text="&#xE710;"
                                   FontFamily="Segoe Fluent Icons"
                                   FontSize="18"
                                   Width="20" Height="20"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>
                    <ListBox x:Name="ProfileList"
                             Grid.Row="1"
                             ItemsSource="{Binding Profiles}"
                             SelectedValuePath="Id"
                             SelectionChanged="ProfileList_SelectionChanged"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ContextMenu>
                            <ContextMenu Opened="ProfileContextMenu_Opened">
                                <MenuItem Header="{localization:Loc Profile_Edit, Fallback=Edit}" Click="EditProfile_Click" />
                                <MenuItem Header="{localization:Loc Profile_Duplicate, Fallback=Duplicate}" Click="DuplicateProfile_Click" />
                                <Separator />
                                <MenuItem x:Name="DeleteProfileMenuItem" Header="{localization:Loc Profile_Delete, Fallback=Delete}" Click="DeleteProfile_Click" />
                            </ContextMenu>
                        </ListBox.ContextMenu>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Height" Value="46" />
                                <Setter Property="Margin" Value="6,2" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="ToolTip" Value="{Binding Name}" />
                                <EventSetter Event="PreviewMouseRightButtonDown" Handler="ProfileItem_PreviewMouseRightButtonDown" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="ItemBorder" Background="Transparent" CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="#303030" />
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="#3A465C" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Icon, Converter={StaticResource ProfileGlyphConverter}}"
                                           FontFamily="Segoe Fluent Icons"
                                           FontSize="20" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Button Grid.Row="2" Margin="7,5" Style="{StaticResource DeckKeyButtonStyle}" Click="Settings_Click" ToolTip="{localization:Loc Nav_Settings.Content, Fallback=Settings}">
                        <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE713;" FontSize="19" />
                    </Button>
                </Grid>
            </Border>

            <Grid Grid.Column="1" Width="424" HorizontalAlignment="Center" Margin="0,4,0,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="46" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="{Binding ObsStatusBrush}" ToolTip="{Binding ObsStatusText}" />
                    <TextBlock Text="OBS" Margin="6,0,0,0" VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Row="1" HorizontalAlignment="Center">
                    <Border Width="320" Height="184" Padding="10,8,10,10"
                            Background="#202020" BorderBrush="#414141" BorderThickness="1" CornerRadius="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="28" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid Margin="2,0">
                                <CheckBox HorizontalAlignment="Right" VerticalAlignment="Center"
                                          Style="{StaticResource ZoneToggleSwitchStyle}"
                                          IsChecked="{Binding CaptureNavigationBlock, Mode=OneWay}"
                                          Click="CaptureNavigationBlock_Click"
                                          ToolTip="{localization:Loc Capture_NavigationBlockHint, Fallback=Intercept the navigation block}" />
                            </Grid>
                            <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition /><ColumnDefinition /><ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition /><RowDefinition />
                        </Grid.RowDefinitions>
                        <Button Grid.Row="0" Grid.Column="0" Margin="0,0,5,4" Tag="Insert" Click="DeckKey_Click" Style="{StaticResource DeckKeyButtonStyle}" Content="{Binding Tiles[Insert]}" ContentTemplate="{StaticResource DeckKeyTemplate}" />
                        <Button Grid.Row="0" Grid.Column="1" Margin="3,0,3,4" Tag="Home" Click="DeckKey_Click" Style="{StaticResource DeckKeyButtonStyle}" Content="{Binding Tiles[Home]}" ContentTemplate="{StaticResource DeckKeyTemplate}" />
                        <Button Grid.Row="0" Grid.Column="2" Margin="5,0,0,4" Tag="PageUp" Click="DeckKey_Click" Style="{StaticResource DeckKeyButtonStyle}" Content="{Binding Tiles[PageUp]}" ContentTemplate="{StaticResource DeckKeyTemplate}" />
                        <Button Grid.Row="1" Grid.Column="0" Margin="0,4,5,0" Tag="Delete" Click="DeckKey_Click" Style="{StaticResource DeckKeyButtonStyle}" Content="{Binding Tiles[Delete]}" ContentTemplate="{StaticResource DeckKeyTemplate}" />
                        <Button Grid.Row="1" Grid.Column="1" Margin="3,4,3,0" Tag="End" Click="DeckKey_Click" Style="{StaticResource DeckKeyButtonStyle}" Content="{Binding Tiles[End]}" ContentTemplate="{StaticResource DeckKeyTemplate}" />
                        <Button Grid.Row="1" Grid.Column="2" Margin="5,4,0,0" Tag="PageDown" Click="DeckKey_Click" Style="{StaticResource DeckKeyButtonStyle}" Content="{Binding Tiles[PageDown]}" ContentTemplate="{StaticResource DeckKeyTemplate}" />
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Width="420" Height="420" Margin="0,12,0,0" Padding="10,8,10,10"
                            Background="#202020" BorderBrush="#414141" BorderThickness="1" CornerRadius="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="28" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid Margin="2,0">
                                <CheckBox HorizontalAlignment="Right" VerticalAlignment="Center"
                                          Style="{StaticResource ZoneToggleSwitchStyle}"
                                          IsChecked="{Binding CaptureNumpad, Mode=OneWay}"
                                          Click="CaptureNumpad_Click"
                                          ToolTip="{localization:Loc Capture_NumPadHint, Fallback=Intercept NumPad keys}" />
                            </Grid>
                            <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition /><ColumnDefinition /><ColumnDefinition /><ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Grid.Column="0" Margin="0,0,4,4" Background="{Binding NumLockBackground}" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" CornerRadius="10" ToolTip="{localization:Loc Settings_NumLockHint.Text, Fallback=Physical NumLock switches two assignment layers.}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE8AB;" FontSize="20" HorizontalAlignment="Center" />
                                <TextBlock Text="NumLock" Margin="0,4,0,0" FontSize="12" />
                            </StackPanel>
                        </Border>
                        <Button Grid.Row="0" Grid.Column="1" Margin="4,0,4,4" Tag="NumpadDivide" Click="DeckKey_Click" Style="{StaticResource DeckKeyButtonStyle}" Content="{Binding Tiles[NumpadDivide]}" ContentTemplate="{StaticResource DeckKeyTemplate}" />
                        <Button Grid.Row="0" Grid.Column="2" Margin="4,0,4,4" Tag="NumpadMultiply" Click="DeckKey_Click" Style="{StaticResource DeckKeyButtonStyle}" Content="{Binding Tiles[NumpadMultiply]}" ContentTemplate="{StaticResource DeckKeyTemplate}" />
                        <Button Grid.Row="0" Grid.Column="3" Margin="4,0,0,4" Tag="NumpadSubtract" Click="DeckKey_Click" Style="{StaticResource DeckKeyButtonStyle}" Content="{Binding Tiles[NumpadSubtract]}" ContentTemplate="{StaticResource DeckKeyTemplate}" />

                        <Button Grid.Row="1" Grid.Column="0" Margin="0,4,4,4" Tag="Numpad7" Click="DeckKey_Click" Style="{StaticResource DeckKeyButtonStyle}" Content="{Binding Tiles[Numpad7]}" ContentTemplate="{StaticResource DeckKeyTemplate}" />
                        <Button Grid.Row="1" Grid.Column="1" Margin="4" Tag="Numpad8" Click="DeckKey_Click" Style="{StaticResource DeckKeyButtonStyle}" Content="{Binding Tiles[Numpad8]}" ContentTemplate="{StaticResource DeckKeyTemplate}" />
                        <Button Grid.Row="1" Grid.Column="2" Margin="4" Tag="Numpad9" Click="DeckKey_Click" Style="{StaticResource DeckKeyButtonStyle}" Content="{Binding Tiles[Numpad9]}" ContentTemplate="{StaticResource DeckKeyTemplate}" />
                        <Button Grid.Row="1" Grid.RowSpan="2" Grid.Column="3" Margin="4,4,0,4" Tag="NumpadAdd" Click="DeckKey_Click" Style="{StaticResource DeckKeyButtonStyle}" Content="{Binding Tiles[NumpadAdd]}" ContentTemplate="{StaticResource DeckKeyTemplate}" />

                        <Button Grid.Row="2" Grid.Column="0" Margin="0,4,4,4" Tag="Numpad4" Click="DeckKey_Click" Style="{StaticResource DeckKeyButtonStyle}" Content="{Binding Tiles[Numpad4]}" ContentTemplate="{StaticResource DeckKeyTemplate}" />
                        <Button Grid.Row="2" Grid.Column="1" Margin="4" Tag="Numpad5" Click="DeckKey_Click" Style="{StaticResource DeckKeyButtonStyle}" Content="{Binding Tiles[Numpad5]}" ContentTemplate="{StaticResource DeckKeyTemplate}" />
                        <Button Grid.Row="2" Grid.Column="2" Margin="4" Tag="Numpad6" Click="DeckKey_Click" Style="{StaticResource DeckKeyButtonStyle}" Content="{Binding Tiles[Numpad6]}" ContentTemplate="{StaticResource DeckKeyTemplate}" />

                        <Button Grid.Row="3" Grid.Column="0" Margin="0,4,4,4" Tag="Numpad1" Click="DeckKey_Click" Style="{StaticResource DeckKeyButtonStyle}" Content="{Binding Tiles[Numpad1]}" ContentTemplate="{StaticResource DeckKeyTemplate}" />
                        <Button Grid.Row="3" Grid.Column="1" Margin="4" Tag="Numpad2" Click="DeckKey_Click" Style="{StaticResource DeckKeyButtonStyle}" Content="{Binding Tiles[Numpad2]}" ContentTemplate="{StaticResource DeckKeyTemplate}" />
                        <Button Grid.Row="3" Grid.Column="2" Margin="4" Tag="Numpad3" Click="DeckKey_Click" Style="{StaticResource DeckKeyButtonStyle}" Content="{Binding Tiles[Numpad3]}" ContentTemplate="{StaticResource DeckKeyTemplate}" />
                        <Button Grid.Row="3" Grid.RowSpan="2" Grid.Column="3" Margin="4,4,0,0" Tag="NumpadEnter" Click="DeckKey_Click" Style="{StaticResource DeckKeyButtonStyle}" Content="{Binding Tiles[NumpadEnter]}" ContentTemplate="{StaticResource DeckKeyTemplate}" />

                        <Button Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,4,4,0" Tag="Numpad0" Click="DeckKey_Click" Style="{StaticResource DeckKeyButtonStyle}" Content="{Binding Tiles[Numpad0]}" ContentTemplate="{StaticResource DeckKeyTemplate}" />
                        <Button Grid.Row="4" Grid.Column="2" Margin="4,4,4,0" Tag="NumpadDecimal" Click="DeckKey_Click" Style="{StaticResource DeckKeyButtonStyle}" Content="{Binding Tiles[NumpadDecimal]}" ContentTemplate="{StaticResource DeckKeyTemplate}" />
                            </Grid>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>

        <Border Grid.Row="1" Panel.ZIndex="20"
                Margin="70,10,12,0" Padding="12,10"
                VerticalAlignment="Top"
                Background="#3A2022" BorderBrush="#D13438" BorderThickness="1" CornerRadius="8">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasError}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="&#xEA39;" FontFamily="Segoe Fluent Icons" FontSize="16"
                           Foreground="#FF99A4" Margin="0,2,10,0" />
                <StackPanel Grid.Column="1">
                    <TextBlock Text="{Binding ErrorTitle}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding ErrorText}" Margin="0,3,0,0"
                               Foreground="#FFD9DC" TextWrapping="Wrap" />
                </StackPanel>
                <Button Grid.Column="2" Width="30" Height="30" Margin="8,-5,-7,-5"
                        Padding="0" Background="Transparent" BorderThickness="0"
                        Click="ErrorDismiss_Click" ToolTip="{localization:Loc Common_Close, Fallback=Close}">
                    <TextBlock Text="&#xE8BB;" FontFamily="Segoe Fluent Icons" FontSize="11"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
