<Window x:Class="StreamNumDeck.Wpf.KeyEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:localization="clr-namespace:StreamNumDeck.Wpf.Localization"
        Width="800" Height="912"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True"
        ResizeMode="NoResize" Background="Transparent"
        Foreground="#F5F5F5" ShowInTaskbar="False">
    <Window.Resources>
        <Style x:Key="PickerItemStyle" TargetType="ListBoxItem">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="44" />
            <Setter Property="Margin" Value="3" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="ToolTip" Value="{Binding Name}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="PickerBorder"
                                Background="#2B2B2B"
                                BorderBrush="#404040"
                                BorderThickness="1"
                                CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PickerBorder" Property="Background" Value="#383838" />
                                <Setter TargetName="PickerBorder" Property="BorderBrush" Value="#686868" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="PickerBorder" Property="Background" Value="#3A4A68" />
                                <Setter TargetName="PickerBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GroupItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="GroupBorder"
                                Width="144" Height="42"
                                Background="#292929"
                                BorderBrush="#454545"
                                BorderThickness="1"
                                CornerRadius="7"
                                Padding="12,0">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="GroupBorder" Property="Background" Value="#353535" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="GroupBorder" Property="Background" Value="#34435E" />
                                <Setter TargetName="GroupBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionItemStyle" TargetType="ListBoxItem">
            <Setter Property="Width" Value="164" />
            <Setter Property="Height" Value="58" />
            <Setter Property="Margin" Value="3" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="ToolTip" Value="{Binding ToolTip}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ActionBorder"
                                Background="#292929"
                                BorderBrush="#414141"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="10,7">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ActionBorder" Property="Background" Value="#363636" />
                                <Setter TargetName="ActionBorder" Property="BorderBrush" Value="#686868" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ActionBorder" Property="Background" Value="#34435E" />
                                <Setter TargetName="ActionBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="10" Background="#202020" BorderBrush="#4B4B4B" BorderThickness="1" CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="22" ShadowDepth="5" Opacity="0.55" Color="#000000" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44" />
                <RowDefinition Height="*" />
                <RowDefinition Height="64" />
            </Grid.RowDefinitions>

            <Border Background="#262626" CornerRadius="12,12,0,0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                               Margin="18,0,48,0" VerticalAlignment="Center"
                               FontSize="13" FontWeight="SemiBold" />
                    <Button HorizontalAlignment="Right" Width="44" Height="44"
                            Background="Transparent" BorderThickness="0"
                            Click="Close_Click" ToolTip="{localization:Loc Common_Cancel, Fallback=Cancel}">
                        <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE8BB;" FontSize="12" />
                    </Button>
                </Grid>
            </Border>

            <ScrollViewer x:Name="EditorScrollViewer" Grid.Row="1"
                          VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="22,16,22,20">
                    <Border x:Name="ValidationBorder" Visibility="Collapsed"
                            Background="#3A2022" BorderBrush="#D13438" BorderThickness="1"
                            CornerRadius="7" Padding="12,9" Margin="0,0,0,14">
                        <DockPanel>
                            <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xEA39;" Foreground="#FF99A4" Margin="0,0,9,0" />
                            <TextBlock x:Name="ValidationText" Foreground="#FFD9DC" TextWrapping="Wrap" />
                        </DockPanel>
                    </Border>

                    <StackPanel x:Name="AppearanceSection">
                    <TextBlock Text="{localization:Loc Editor_Appearance.Text, Fallback=Appearance}"
                               FontSize="16" FontWeight="SemiBold" />
                    <TextBlock Text="{localization:Loc ProfileIcon.Text, Fallback=Choose how the key will look}"
                               Foreground="{StaticResource SecondaryTextBrush}" Margin="0,3,0,12" />

                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="96" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <Border Width="88" Height="88" HorizontalAlignment="Center" VerticalAlignment="Center"
                                Background="#2B2B2B" BorderBrush="#505050" BorderThickness="1" CornerRadius="10">
                            <Grid>
                                <TextBlock x:Name="IconPreviewGlyph" FontFamily="Segoe Fluent Icons" FontSize="34"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                <Image x:Name="IconPreviewImage" Margin="10" Stretch="Uniform" Visibility="Collapsed" />
                            </Grid>
                        </Border>

                        <StackPanel Grid.Column="1">
                            <ListBox x:Name="IconListBox" Height="150"
                                     Background="Transparent" BorderThickness="0" Padding="0"
                                     SelectedValuePath="Id" SelectionChanged="IconListBox_SelectionChanged"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ItemContainerStyle="{StaticResource PickerItemStyle}">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Glyph}" FontFamily="Segoe Fluent Icons" FontSize="20"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <StackPanel Orientation="Horizontal" Margin="3,8,0,0">
                                <Button x:Name="CustomIconButton"
                                        Content="{localization:Loc Editor_CustomIcon.Content, Fallback=Choose a custom icon…}"
                                        Height="32" Click="CustomIcon_Click" />
                                <TextBlock x:Name="CustomIconFileName" Margin="10,0,0,0"
                                           MaxWidth="190" VerticalAlignment="Center"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,15,0,0">
                        <Grid.ColumnDefinitions><ColumnDefinition /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="{localization:Loc Editor_Label.Header, Fallback=Label}" Margin="0,0,0,6" />
                            <TextBox x:Name="LabelTextBox" Height="34" MaxLength="40" />
                        </StackPanel>
                        <Button x:Name="CopyOtherLayerButton" Grid.Column="1"
                                Height="34" VerticalAlignment="Bottom" Click="CopyOtherLayer_Click" />
                    </Grid>

                    <Border Height="1" Background="#414141" Margin="0,20,0,18" />
                    </StackPanel>

                    <TextBlock Text="{localization:Loc Editor_ActionSection.Text, Fallback=Action}"
                               FontSize="16" FontWeight="SemiBold" />
                    <TextBlock Text="{localization:Loc Editor_ActionGroup.Header, Fallback=Choose a group and an action}"
                               Foreground="{StaticResource SecondaryTextBrush}" Margin="0,3,0,12" />

                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="144" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <ListBox x:Name="ActionGroupListBox"
                                 Background="Transparent" BorderThickness="0" Padding="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                 PreviewMouseWheel="NestedActionList_PreviewMouseWheel"
                                 SelectionChanged="ActionGroupListBox_SelectionChanged"
                                 ItemContainerStyle="{StaticResource GroupItemStyle}">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate><StackPanel /></ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="26" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Glyph}" FontFamily="Segoe Fluent Icons" FontSize="18" Width="26" />
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center"
                                                   TextWrapping="Wrap" FontSize="11" LineHeight="14" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <ListBox x:Name="ActionListBox" Grid.Column="2" Margin="-3,-3,-3,0"
                                 Background="Transparent" BorderThickness="0" Padding="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                 PreviewMouseWheel="NestedActionList_PreviewMouseWheel"
                                 SelectionChanged="ActionListBox_SelectionChanged"
                                 ItemContainerStyle="{StaticResource ActionItemStyle}">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="30" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Glyph}" FontFamily="Segoe Fluent Icons" FontSize="20"
                                                   VerticalAlignment="Center" Foreground="#BFD0FF" />
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center"
                                                   TextWrapping="Wrap" FontSize="12" LineHeight="15" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                    <Border x:Name="AutomationPanel" Grid.Column="2" Margin="-3,-3,-3,0" Padding="14"
                            Background="#262626" BorderBrush="#414141" BorderThickness="1"
                            CornerRadius="9" Visibility="Collapsed" VerticalAlignment="Top">
                        <StackPanel>
                            <ItemsControl x:Name="AutomationStepsItemsControl">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,7" Padding="10,8"
                                                BorderThickness="1" CornerRadius="7">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#2E2E2E" />
                                                    <Setter Property="BorderBrush" Value="#494949" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsFinish}" Value="True">
                                                            <Setter Property="BorderBrush" Value="#866B2E" />
                                                            <Setter Property="Background" Value="#332E22" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="32" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Glyph}" FontFamily="Segoe Fluent Icons"
                                                           FontSize="18" Foreground="#BFD0FF"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                <StackPanel Grid.Column="1" Margin="8,0,8,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="SemiBold"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding Detail}" Margin="0,2,0,0" FontSize="10"
                                                               Foreground="{StaticResource SecondaryTextBrush}"
                                                               TextWrapping="Wrap" />
                                                    <StackPanel x:Name="PauseEditor" Orientation="Horizontal"
                                                                Margin="0,6,0,0" Visibility="Collapsed">
                                                        <TextBox Width="86" Height="30"
                                                                 Text="{Binding SecondsText, UpdateSourceTrigger=PropertyChanged}"
                                                                 LostFocus="PauseSeconds_LostFocus" />
                                                        <TextBlock Text="{localization:Loc Automation_Seconds, Fallback=seconds}"
                                                                   Margin="8,0,0,0" VerticalAlignment="Center"
                                                                   Foreground="{StaticResource SecondaryTextBrush}" />
                                                    </StackPanel>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Button x:Name="EditAutomationStepButton" Width="30" Height="30" Margin="0,0,4,0"
                                                            Padding="0" Click="EditAutomationStep_Click"
                                                            ToolTip="{localization:Loc Common_Edit, Fallback=Edit}">
                                                        <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE70F;" FontSize="12" />
                                                    </Button>
                                                    <Button Width="30" Height="30" Margin="0,0,4,0" Padding="0"
                                                            Click="MoveAutomationStepUp_Click"
                                                            ToolTip="{localization:Loc Automation_MoveUp, Fallback=Move up}">
                                                        <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE74A;" FontSize="12" />
                                                    </Button>
                                                    <Button Width="30" Height="30" Margin="0,0,4,0" Padding="0"
                                                            Click="MoveAutomationStepDown_Click"
                                                            ToolTip="{localization:Loc Automation_MoveDown, Fallback=Move down}">
                                                        <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE74B;" FontSize="12" />
                                                    </Button>
                                                    <Button Width="30" Height="30" Padding="0" Click="RemoveAutomationStep_Click"
                                                            ToolTip="{localization:Loc Common_Delete, Fallback=Delete}">
                                                        <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE74D;" FontSize="12" />
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsPause}" Value="True">
                                                <Setter TargetName="PauseEditor" Property="Visibility" Value="Visible" />
                                                <Setter TargetName="EditAutomationStepButton" Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsFinish}" Value="True">
                                                <Setter TargetName="EditAutomationStepButton" Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Button x:Name="AddAutomationStepButton" Width="46" Height="38"
                                    HorizontalAlignment="Center" Padding="0"
                                    Click="AddAutomationStep_Click"
                                    ToolTip="{localization:Loc Automation_AddStep, Fallback=Add step}">
                                <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE710;" FontSize="17"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Button>

                            <Border x:Name="AutomationAddMenu" Margin="0,9,0,0" Padding="8"
                                    Background="#303030" BorderBrush="#505050" BorderThickness="1"
                                    CornerRadius="7" Visibility="Collapsed">
                                <UniformGrid Columns="3">
                                    <Button Margin="3" MinHeight="48" Click="AddAutomationAction_Click">
                                        <StackPanel>
                                            <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE710;" FontSize="16" HorizontalAlignment="Center" />
                                            <TextBlock Text="{localization:Loc Automation_AddAction, Fallback=Action}" FontSize="11" />
                                        </StackPanel>
                                    </Button>
                                    <Button Margin="3" MinHeight="48" Click="AddAutomationPause_Click">
                                        <StackPanel>
                                            <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE916;" FontSize="18" HorizontalAlignment="Center" />
                                            <TextBlock Text="{localization:Loc Automation_Pause, Fallback=Pause}" FontSize="11" />
                                        </StackPanel>
                                    </Button>
                                    <Button Margin="3" MinHeight="48" Click="AddAutomationFinish_Click">
                                        <StackPanel>
                                            <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE71A;" FontSize="18" HorizontalAlignment="Center" />
                                            <TextBlock Text="{localization:Loc Automation_Finish, Fallback=Finish}" FontSize="11" />
                                        </StackPanel>
                                    </Button>
                                </UniformGrid>
                            </Border>
                        </StackPanel>
                    </Border>
                    </Grid>

                    <Border x:Name="ActionParametersCard" Margin="0,14,0,0" Padding="14"
                            Background="#262626" BorderBrush="#414141" BorderThickness="1" CornerRadius="9">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock x:Name="ParameterLabel" Margin="0,0,0,6" />
                            <StackPanel Grid.Row="1">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <TextBox x:Name="ParameterTextBox" Height="34" MaxHeight="130"
                                             VerticalAlignment="Top" VerticalContentAlignment="Top"
                                             AcceptsReturn="True" VerticalScrollBarVisibility="Auto" />
                                    <ComboBox x:Name="ParameterComboBox" IsEditable="True" Height="34"
                                              VerticalAlignment="Top" Visibility="Collapsed" />
                                    <Button x:Name="BrowseButton" Grid.Column="1"
                                            Content="{localization:Loc Common_BrowseButton.Content, Fallback=Browse…}"
                                            MinWidth="86" Height="34" Margin="8,0,0,0"
                                            VerticalAlignment="Top" Click="Browse_Click" />
                                </Grid>
                                <TextBlock x:Name="ParameterHint" Margin="0,7,0,0"
                                           FontSize="11" Foreground="{StaticResource SecondaryTextBrush}"
                                           TextWrapping="Wrap" Visibility="Collapsed" />
                            </StackPanel>

                            <StackPanel x:Name="VolumePanel" Grid.Row="1" Margin="0,50,0,0">
                                <DockPanel>
                                    <TextBlock Text="{localization:Loc Editor_VolumeStep.Header, Fallback=Volume / step (%)}" />
                                    <TextBlock x:Name="VolumeValueText" DockPanel.Dock="Right" TextAlignment="Right" />
                                </DockPanel>
                                <Slider x:Name="VolumeSlider" Margin="0,5,0,0" Minimum="1" Maximum="100"
                                        ValueChanged="VolumeSlider_ValueChanged" />
                                <StackPanel x:Name="SoundBehaviorPanel" Margin="0,9,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                        <ComboBox x:Name="SoundBehaviorComboBox" DisplayMemberPath="Name" SelectedValuePath="Value" />
                                        <Button Grid.Column="1" Margin="8,0,0,0"
                                                Content="{localization:Loc Editor_PreviewSound.Content, Fallback=Preview}"
                                                Click="PreviewSound_Click" />
                                        <Button Grid.Column="2" Margin="8,0,0,0"
                                                Content="{localization:Loc Common_StopButton.Content, Fallback=Stop}"
                                                Click="StopSound_Click" />
                                    </Grid>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel x:Name="LaunchOptionsPanel" Grid.Row="1" Margin="0,50,0,0" Visibility="Collapsed">
                                <TextBlock Text="{localization:Loc Editor_Arguments.Header, Fallback=Arguments}" Margin="0,0,0,5" />
                                <TextBox x:Name="ArgumentsTextBox" Height="34" />
                                <TextBlock Text="{localization:Loc Editor_WorkingDirectory.Header, Fallback=Working directory}" Margin="0,10,0,5" />
                                <TextBox x:Name="WorkingDirectoryTextBox" Height="34" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" Background="#262626" BorderBrush="#3C3C3C" BorderThickness="0,1,0,0" CornerRadius="0,0,12,12">
                <Grid Margin="18,0">
                    <Button x:Name="RemoveButton" Content="{localization:Loc Editor_Dialog.SecondaryButtonText, Fallback=Clear}"
                            MinWidth="84" HorizontalAlignment="Left" Click="Remove_Click" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="{localization:Loc Common_Cancel, Fallback=Cancel}"
                                MinWidth="84" Margin="0,0,8,0" IsCancel="True" />
                        <Button Content="{localization:Loc Common_Save, Fallback=Save}"
                                MinWidth="88" IsDefault="True" Click="Save_Click" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
