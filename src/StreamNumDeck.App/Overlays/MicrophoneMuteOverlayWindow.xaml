<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="StreamNumDeck.App.Overlays.MicrophoneMuteOverlayWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid
        x:Name="DragSurface"
        Background="#E6C42B35"
        PointerCanceled="DragSurface_PointerCanceled"
        PointerCaptureLost="DragSurface_PointerCaptureLost"
        PointerMoved="DragSurface_PointerMoved"
        PointerPressed="DragSurface_PointerPressed"
        PointerReleased="DragSurface_PointerReleased">
        <FontIcon
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            FontSize="27"
            Foreground="White"
            Glyph="&#xE720;" />
        <Rectangle
            Width="4"
            Height="38"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Fill="White"
            RadiusX="2"
            RadiusY="2"
            RenderTransformOrigin="0.5,0.5">
            <Rectangle.RenderTransform>
                <RotateTransform Angle="-45" />
            </Rectangle.RenderTransform>
        </Rectangle>
    </Grid>
</Window>
