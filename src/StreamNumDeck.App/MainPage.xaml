<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="StreamNumDeck.App.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <DataTemplate x:Key="ProfileIconTemplate">
            <StackPanel
                Width="72"
                Padding="6"
                HorizontalAlignment="Center"
                Spacing="6">
                <FontIcon
                    HorizontalAlignment="Center"
                    FontSize="22"
                    Glyph="{Binding Glyph}" />
                <TextBlock
                    HorizontalAlignment="Center"
                    FontSize="12"
                    MaxLines="1"
                    Text="{Binding Name}"
                    TextAlignment="Center"
                    TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <NavigationView
            x:Name="ShellNavigation"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            IsTitleBarAutoPaddingEnabled="False"
            Loaded="ShellNavigation_Loaded"
            PaneDisplayMode="LeftCompact"
            SelectionChanged="ShellNavigation_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem
                    x:Name="NewProfileNavigationItem"
                    x:Uid="Nav_NewProfile"
                    Content="Новый профиль"
                    Tag="new-profile"
                    ToolTipService.ToolTip="Новый профиль">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Add" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>
            <NavigationView.FooterMenuItems>
                <NavigationViewItem x:Uid="Nav_Settings" Content="Настройки" Tag="settings">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Setting" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <Frame x:Name="ContentFrame" />
        </NavigationView>

        <ContentDialog
            x:Name="NewProfileDialog"
            x:Uid="ProfileDialog"
            CloseButtonText="Отмена"
            DefaultButton="Primary"
            PrimaryButtonClick="NewProfileDialog_PrimaryButtonClick"
            PrimaryButtonText="Создать"
            Title="Новый профиль">
            <StackPanel Spacing="14">
                <TextBox
                    x:Name="ProfileNameTextBox"
                    x:Uid="ProfileName"
                    Header="Название"
                    MaxLength="80"
                    PlaceholderText="Например, Игровой стрим"
                    TextChanged="ProfileNameTextBox_TextChanged" />
                <TextBlock
                    x:Name="ProfileDialogError"
                    Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                    TextWrapping="Wrap"
                    Visibility="Collapsed" />
                <TextBlock x:Uid="ProfileIcon" Style="{StaticResource BodyStrongTextBlockStyle}" Text="Иконка" />
                <GridView
                    x:Name="ProfileIconGrid"
                    Height="190"
                    HorizontalAlignment="Stretch"
                    ItemTemplate="{StaticResource ProfileIconTemplate}"
                    ItemsSource="{x:Bind BuiltInIconOptions}"
                    SelectionMode="Single">
                    <GridView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </GridView.ItemsPanel>
                </GridView>
            </StackPanel>
        </ContentDialog>
    </Grid>
</Page>
